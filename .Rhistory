############################################################
# 07_iv_analysis.R
#
# Purpose: IV Estimation of Supply Inelasticity using
# WWII Destruction Shares as an instrument.
############################################################
library(tidyverse)
library(fixest)
library(modelsummary)
# ----------------------------- 1. Setup Data -----------------------------
# We pull data from the results_all object created in script 05
if(!exists("results_all")) {
stop("Please run 05_regressions.R first to generate the 'results_all' object.")
}
############################################################
# 07_iv_analysis.R
#
# Purpose: IV Estimation of Supply Inelasticity using
# WWII Destruction Shares as an instrument.
############################################################
library(tidyverse)
library(fixest)
library(modelsummary)
# ----------------------------- 1. Load Data -----------------------------
# Use the same file paths as in 05_regressions.R
static_data_raw <- read_csv("data/processed/superstar_panel_global.csv", show_col_types = FALSE)
lagged_data_raw <- read_csv("data/processed/superstar_panel_period.csv", show_col_types = FALSE)
# ----------------------------- 2. Helper for IV -----------------------------
prepare_iv_data <- function(df) {
df %>%
filter(
!is.na(growth_window),
growth_window != "1995-1999"
) %>%
mutate(
log_price = log(value),
# Ensure year and city are factors for fixed effects
year_f = as.factor(year),
city_f = as.factor(city)
) %>%
# Filter for observations that have both the instrument and the endogenous variable
filter(!is.na(p_q5), !is.na(destruction_share))
}
iv_static <- prepare_iv_data(static_data_raw)
iv_lagged <- prepare_iv_data(lagged_data_raw)
# ----------------------------- 3. Model Estimation -----------------------------
# --- Static Specification ---
# First Stage: p_q5 ~ destruction_share
fs_static <- feols(p_q5 ~ destruction_share + east_germany | year_f,
data = iv_static, cluster = ~city)
# Second Stage: log_price ~ instrumented p_q5
ss_static <- feols(log_price ~ east_germany | year_f | p_q5 ~ destruction_share,
data = iv_static, cluster = ~city)
# --- Lagged Specification ---
fs_lagged <- feols(p_q5 ~ destruction_share + east_germany | year_f,
data = iv_lagged, cluster = ~city)
ss_lagged <- feols(log_price ~ east_germany | year_f | p_q5 ~ destruction_share,
data = iv_lagged, cluster = ~city)
# ----------------------------- 4. Export to LaTeX -----------------------------
iv_list <- list(
"First Stage (Static)" = fs_static,
"2SLS (Static)"        = ss_static,
"First Stage (Lagged)" = fs_lagged,
"2SLS (Lagged)"        = ss_lagged
)
# Create the tables folder if it doesn't exist
if(!dir.exists("output/tables")) dir.create("output/tables", recursive = TRUE)
msummary(iv_list,
output = "output/tables/appendix_iv_results.tex",
stars = c('+'=.1, '*'=.05, '**'=.01, '***'=.001),
coef_map = c("destruction_share" = "WWII Destruction Share",
"p_q5" = "Supply Inelasticity ($P/Q$)",
"east_germany" = "East Germany"),
gof_map = c("nobs", "adj.r.squared"),
title = "Instrumental Variable Results: Supply Inelasticity")
message("Success: IV tables exported to output/tables/appendix_iv_results.tex")
############################################################
# 06_iv_analysis.R
#
# Purpose: IV Estimation of Supply Inelasticity using
# WWII Destruction Shares as an instrument.
# Formatted for LaTeX tabular output.
############################################################
library(tidyverse)
library(fixest)
# ----------------------------- 1. Load Data -----------------------------
static_data_raw <- read_csv("data/processed/superstar_panel_global.csv", show_col_types = FALSE)
# ----------------------------- 2. Prepare Data -----------------------------
iv_data <- static_data_raw %>%
filter(
!is.na(growth_window),
growth_window != "1995-1999"
) %>%
mutate(
log_price = log(value),
year_f = as.factor(year)
) %>%
filter(!is.na(p_q5), !is.na(destruction_share))
# ----------------------------- 3. IV Model -----------------------------
# We estimate the IV model once. fixest allows us to extract
# both stages from this single object.
iv_model <- feols(log_price ~ east_germany | year_f | p_q5 ~ destruction_share,
data = iv_data,
cluster = ~city)
# Extract the stages
# stage = 1: First stage (p_q5 ~ destruction_share)
# stage = 2: Second stage (log_price ~ instrumented p_q5)
iv_results <- summary(iv_model, stage = 1:2)
# ----------------------------- 4. Export Table -----------------------------
# Define a dictionary for professional variable names
var_dict <- c(
"destruction_share" = "WWII Destruction",
"p_q5"              = "Housing Inelasticity",
"east_germany"      = "east",
"log_price"         = "log_price",
"fit_p_q5"          = "Housing Inelasticity" # Label for instrumented var in 2nd stage
)
# Customizing the etable to match your template
etable(iv_results,
title    = "IV Regression Results for Housing Inelasticity and Prices",
label    = "tab:iv_results",
headers  = list("IV stages" = c("First", "Second")),
dict     = var_dict,
# Choose specific fit statistics: n (obs), ivf1 (First stage F), ivwald2 (Hausman)
fitstat  = ~ n + ivf1 + ivwald2,
# Format to match your style
style.tex = style.tex("aer", model.format = "(1)"),
notes    = c("Clustered (city) standard-errors in parentheses.", "***: 0.01, **: 0.05, *: 0.1"),
file     = "output/tables/appendix_iv_results.tex",
replace  = TRUE)
message("Success: Table generated in output/tables/appendix_iv_results.tex")
