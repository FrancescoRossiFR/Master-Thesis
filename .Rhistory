stars = stars,
gof_map = c("nobs", "adj.r.squared"),
add_rows = tribble(
~term, ~M1, ~M2, ~M3, ~M4,
"Identification", "Static", "Static", "Lagged", "Lagged",
"Fixed effects", "Period", "Period + City", "Period", "Period + City"
),
